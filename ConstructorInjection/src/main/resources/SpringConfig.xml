<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    <bean id="std" class="org.example.Student" autowire="constructor">
        <constructor-arg index="0" value="23"/>
        <constructor-arg index="1" value="1"/>
<!--        <constructor-arg index="2" ref="p"/>-->

    </bean>
    <bean id="p" class="org.example.Pen">

    </bean>
    <bean id="pc" class="org.example.Pencil" primary="true">

    </bean>
    <bean id="sk" class="org.example.Sketch">

    </bean>

</beans>